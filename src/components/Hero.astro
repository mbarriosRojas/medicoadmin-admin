---
---

<section id="home" class="hero">
  <div class="slider">
    <div class="slide active">
      <div class="container slide-content">
        <div class="slide-text">
          <h1>Bienvenido a MedicoAdmin</h1>
          <p>Tu farmacia de confianza con los mejores productos para tu salud y bienestar</p>
          <div class="slide-buttons">
            <a href="#productos" class="btn btn-primary">Ver Productos</a>
            <a href="#promociones" class="btn btn-secondary">Promociones</a>
          </div>
        </div>
        <div class="slide-image">
          <svg width="400" height="300" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="50" y="50" width="300" height="200" rx="20" fill="#e0e7ff"/>
            <rect x="100" y="100" width="80" height="100" rx="10" fill="#2563eb"/>
            <rect x="220" y="100" width="80" height="100" rx="10" fill="#10b981"/>
            <circle cx="140" cy="130" r="15" fill="white"/>
            <circle cx="260" cy="130" r="15" fill="white"/>
          </svg>
        </div>
      </div>
    </div>
    
    <div class="slide">
      <div class="container slide-content">
        <div class="slide-text">
          <h1>Ofertas Especiales</h1>
          <p>Descuentos de hasta 50% en productos seleccionados</p>
          <div class="slide-buttons">
            <a href="#promociones" class="btn btn-primary">Ver Ofertas</a>
          </div>
        </div>
        <div class="slide-image">
          <svg width="400" height="300" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="200" cy="150" r="100" fill="#fef3c7"/>
            <text x="200" y="165" text-anchor="middle" font-size="48" font-weight="bold" fill="#f59e0b">50%</text>
            <text x="200" y="195" text-anchor="middle" font-size="24" fill="#d97706">OFF</text>
          </svg>
        </div>
      </div>
    </div>
    
    <div class="slide">
      <div class="container slide-content">
        <div class="slide-text">
          <h1>Productos de Calidad</h1>
          <p>Medicamentos y suplementos certificados para tu salud</p>
          <div class="slide-buttons">
            <a href="#productos" class="btn btn-primary">Explorar</a>
          </div>
        </div>
        <div class="slide-image">
          <svg width="400" height="300" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="100" y="80" width="200" height="140" rx="15" fill="#dcfce7"/>
            <path d="M200 120L200 200M160 160L240 160" stroke="#10b981" stroke-width="8" stroke-linecap="round"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
  
  <div class="slider-controls">
    <button class="prev" aria-label="Anterior">‹</button>
    <div class="slider-dots">
      <button class="dot active" data-slide="0"></button>
      <button class="dot" data-slide="1"></button>
      <button class="dot" data-slide="2"></button>
    </div>
    <button class="next" aria-label="Siguiente">›</button>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    min-height: 500px;
    overflow: hidden;
  }

  .slider {
    position: relative;
    height: 100%;
  }

  .slide {
    display: none;
    padding: var(--spacing-2xl) 0;
  }

  .slide.active {
    display: block;
    animation: fadeIn 0.5s ease-in;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateX(20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .slide-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .slide-text {
    color: white;
  }

  .slide-text h1 {
    font-size: 3rem;
    margin-bottom: var(--spacing-md);
  }

  .slide-text p {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-lg);
    opacity: 0.9;
  }

  .slide-buttons {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .slide-image {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .slider-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-md);
    padding-bottom: var(--spacing-lg);
  }

  .prev,
  .next {
    background-color: rgba(255, 255, 255, 0.3);
    color: white;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .prev:hover,
  .next:hover {
    background-color: rgba(255, 255, 255, 0.5);
  }

  .slider-dots {
    display: flex;
    gap: var(--spacing-xs);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.5);
    padding: 0;
  }

  .dot.active {
    background-color: white;
  }

  @media (max-width: 768px) {
    .slide-content {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .slide-text h1 {
      font-size: 2rem;
    }

    .slide-image {
      display: none;
    }

    .slide-buttons {
      justify-content: center;
    }
  }
</style>

<script>
  let currentSlide = 0;
  const slides = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.dot');
  const prevBtn = document.querySelector('.prev');
  const nextBtn = document.querySelector('.next');

  function showSlide(n: number) {
    slides[currentSlide].classList.remove('active');
    dots[currentSlide].classList.remove('active');
    
    currentSlide = (n + slides.length) % slides.length;
    
    slides[currentSlide].classList.add('active');
    dots[currentSlide].classList.add('active');
  }

  prevBtn?.addEventListener('click', () => showSlide(currentSlide - 1));
  nextBtn?.addEventListener('click', () => showSlide(currentSlide + 1));

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => showSlide(index));
  });

  setInterval(() => {
    showSlide(currentSlide + 1);
  }, 5000);
</script>
